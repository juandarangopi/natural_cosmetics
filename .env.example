# Lemon Squeezy credentials
# Get these from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_api_key_here

# Your store ID (numeric, found in LS dashboard URL or Store settings)
LEMONSQUEEZY_STORE_ID=12345

# Webhook signing secret (generated when creating a webhook in LS dashboard)
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# CORS — restrict to your domain in production (e.g. https://yourdomain.com)
ALLOWED_ORIGINS=*

# Lemon Squeezy direct checkout URL (from LS dashboard → Checkouts)
LS_CHECKOUT_URL=https://yourstore.lemonsqueezy.com/checkout/buy/your-uuid

# Lemon Squeezy variant ID (numeric, used for dynamic checkout via API)
LS_VARIANT_ID=
